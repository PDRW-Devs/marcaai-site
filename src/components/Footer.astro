---
// Porte Astro do componente React "Footer" (shadcn-style): logo + sociais no
// topo, divisor, links principais e legais à direita, copyright à esquerda.
const year = new Date().getFullYear();

const sociais = [
  {
    label: 'Instagram',
    href: 'https://instagram.com/',
    icone:
      'M16 4H8a4 4 0 0 0-4 4v8a4 4 0 0 0 4 4h8a4 4 0 0 0 4-4V8a4 4 0 0 0-4-4zM12 15.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7zM16.75 7.3h.01',
  },
  {
    label: 'WhatsApp',
    href: 'https://wa.me/',
    icone:
      'M12 3a9 9 0 0 0-7.8 13.5L3 21l4.7-1.2A9 9 0 1 0 12 3zM8.7 8.2c.2-.4.4-.4.6-.4h.5c.2 0 .4 0 .5.4l.7 1.7c.1.2 0 .4-.1.5l-.5.6c-.1.2-.1.3 0 .5.3.6 1.2 1.7 2.5 2.3.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.6.8c.3.1.3.3.3.5-.1.6-.7 1.4-1.4 1.5-.6.1-1.4.2-3.5-.9-2.5-1.4-3.5-3.9-3.6-4.2-.1-.3-.5-1.3.3-2.4z',
  },
];

const linksPrincipais = [
  { href: '/#maya', label: 'Conheça a Maya' },
  { href: '/#como-funciona', label: 'Como funciona' },
  { href: 'https://app.marca-ai.online', label: 'Entrar no app' },
];

const linksLegais = [
  { href: '#', label: 'Privacidade' },
  { href: '#', label: 'Termos' },
];
---

<footer class="border-t border-line bg-bg-warm pt-16 pb-6 lg:pt-24 lg:pb-8">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="md:flex md:items-center md:justify-between">
      <a href="/" class="flex items-center gap-x-3" aria-label="Marca AI — início">
        <img
          src="/logo-marca-ai.png"
          alt=""
          width="112"
          height="112"
          class="h-24 w-24 object-contain md:h-28 md:w-28"
          loading="lazy"
        />
        <span class="max-w-56 text-sm text-muted">
          Atendimento, agenda e automação para negócios locais.
        </span>
      </a>

      <ul class="mt-6 flex list-none gap-3 md:mt-0">
        {
          sociais.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={s.label}
                class="flex h-11 w-11 items-center justify-center rounded-full border border-line bg-bg text-ink transition-colors duration-300 hover:border-brand hover:bg-brand hover:text-white"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={s.icone} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-6 border-t border-line pt-6 md:mt-4 md:pt-8 lg:grid lg:grid-cols-10">
      <nav aria-label="Rodapé" class="lg:col-[4/11]">
        <ul class="-mx-2 -my-1 flex list-none flex-wrap lg:justify-end">
          {
            linksPrincipais.map((l) => (
              <li class="mx-2 my-1 shrink-0">
                <a
                  href={l.href}
                  class="text-sm font-medium text-ink underline-offset-4 hover:text-brand hover:underline"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="mt-6 lg:col-[4/11] lg:mt-0">
        <ul class="-mx-3 -my-1 flex list-none flex-wrap lg:justify-end">
          {
            linksLegais.map((l) => (
              <li class="mx-3 my-1 shrink-0">
                <a
                  href={l.href}
                  class="text-sm text-muted underline-offset-4 hover:text-brand hover:underline"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div
        class="mt-6 text-sm leading-6 whitespace-nowrap text-muted lg:col-[1/4] lg:row-[1/3] lg:mt-0"
      >
        <div>© {year} Marca AI</div>
        <div class="font-mono text-xs">marca-ai.online</div>
      </div>
    </div>
  </div>
</footer>
