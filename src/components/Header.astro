{/* Header fixo com efeito de vidro */}
<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line/60 bg-white/55 shadow-[0_1px_20px_-8px_rgba(17,24,39,0.12)] backdrop-blur-xl"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 md:h-28 md:px-8">
    <a href="/" class="flex items-center" aria-label="Marca AI — início">
      <img
        src="/logo-marca-ai.png"
        alt="Marca AI"
        width="192"
        height="192"
        class="h-16 w-16 object-contain md:h-28 md:w-28"
      />
    </a>

    <nav aria-label="Principal" class="flex items-center gap-6 text-sm font-medium text-ink md:gap-10 md:text-base">
      <a href="#maya" class="link-underline">Conheça a Maya</a>
      <a href="#como-funciona" class="link-underline hidden sm:inline">Como funciona</a>
    </nav>
  </div>
</header>
