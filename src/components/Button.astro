---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
  'btn-shine relative inline-flex min-h-11 cursor-pointer items-center justify-center gap-2 rounded-full px-6 py-3 font-sans font-medium transition-[background-color,color,box-shadow] duration-300 [transition-timing-function:var(--ease-out-expo)]';
const variants = {
  primary:
    'bg-brand text-white shadow-[0_8px_24px_-8px_var(--brand)] hover:bg-brand-strong hover:shadow-[0_12px_36px_-8px_var(--brand)]',
  secondary: 'border-2 border-ink text-ink hover:bg-ink hover:text-white',
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</a>
