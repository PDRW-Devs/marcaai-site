<section class="border-y border-line bg-bg-warm py-16 md:py-32">
  <div class="mx-auto max-w-4xl px-5 text-center md:px-8">
    <p class="mb-4 font-mono text-sm tracking-widest text-brand uppercase" data-reveal>
      Quem já usa
    </p>
    <h2 class="text-3xl md:text-5xl" data-reveal>Rodando de verdade, em barbearia de verdade.</h2>

    <figure
      class="mx-auto mt-10 max-w-2xl rounded-3xl border border-line bg-bg p-6 md:mt-14 md:p-12"
      data-reveal
      data-clip
    >
      <blockquote class="text-xl leading-relaxed font-medium md:text-2xl">
        “[depoimento do piloto — preencher]”
      </blockquote>
      <figcaption class="mt-8 flex items-center justify-center gap-4">
        {/* placeholder de foto — substituir por imagem real */}
        <span
          class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-soft font-display text-lg font-bold text-brand"
          aria-hidden="true">VM</span
        >
        <span class="text-left">
          <span class="block font-medium">[nome — preencher]</span>
          <span class="block text-sm text-muted">Espaço Vinícius Maçon · piloto ativo</span>
        </span>
      </figcaption>
    </figure>
  </div>
</section>
