---
// Manifesto sobre fundo "aurora": gradiente laranja da marca com blobs de luz
// animados em canvas (porte vanilla do componente AuroraBackground — sem React).
// Reduced-motion/sem JS: fica só o gradiente estático da marca.
---

<section class="manifesto-aurora relative overflow-hidden border-y border-line py-20 md:py-40">
  <canvas data-aurora class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

  <div class="relative mx-auto max-w-5xl px-5 md:px-8">
    <h2 data-lines class="text-3xl leading-[1.15] font-semibold text-white sm:text-4xl md:text-6xl">
      <span class="block overflow-hidden py-0.5">
        <span class="line-inner block text-white/70">Cliente que espera, desiste.</span>
      </span>
      <span class="block overflow-hidden py-0.5">
        <span class="line-inner block">Cliente respondido na hora, agenda.</span>
      </span>
      <span class="block overflow-hidden py-0.5">
        <span class="line-inner block"
          >A Maya responde na hora. <span class="text-ink">Sempre.</span></span
        >
      </span>
    </h2>
  </div>
</section>

<style>
  .manifesto-aurora {
    background: linear-gradient(160deg, var(--brand) 0%, var(--brand-strong) 60%, #c2470a 100%);
  }
</style>

<script>
  // Aurora em canvas: blobs de gradiente radial derivando devagar, na paleta
  // da marca. Pausa fora da viewport e não roda com prefers-reduced-motion.
  const canvas = document.querySelector<HTMLCanvasElement>('[data-aurora]');
  const reduz = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && !reduz) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      const paleta: [string, string, string][] = [
        ['hsla(28, 100%, 66%, 0.5)', 'hsla(16, 95%, 52%, 0.22)', 'transparent'],
        ['hsla(42, 100%, 70%, 0.42)', 'transparent', 'transparent'],
      ];
      const BLOBS = 5;
      const SPEED = 0.55;
      let t = 0;
      let raf = 0;
      let visivel = false;

      const resize = () => {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize, { passive: true });

      const desenhar = () => {
        t += 0.01 * SPEED;
        const w = canvas.width;
        const h = canvas.height;
        ctx.clearRect(0, 0, w, h);

        for (let i = 0; i < BLOBS; i++) {
          const [c1, c2, c3] = paleta[i % paleta.length];
          const fase = (i / BLOBS) * Math.PI * 2 + t;
          const x = w / 2 + Math.sin(fase) * (w * 0.2) + Math.cos(t * 0.5) * (w * 0.1);
          const y = h / 2 + Math.cos(fase * 0.7) * (h * 0.25) + Math.sin(t * 0.3) * (h * 0.12);
          const g = ctx.createRadialGradient(x, y, 0, x, y, Math.max(w, h) * 0.4);
          g.addColorStop(0, c1);
          g.addColorStop(0.5, c2);
          g.addColorStop(1, c3);
          ctx.fillStyle = g;
          ctx.fillRect(0, 0, w, h);
        }

        ctx.globalCompositeOperation = 'screen';
        for (let i = 0; i < 2; i++) {
          const fase = (i / 2) * Math.PI + t * 0.8;
          const x = w / 2 + Math.sin(fase * 1.2) * (w * 0.15);
          const y = h / 2 + Math.cos(fase * 0.9) * (h * 0.15);
          const g = ctx.createRadialGradient(x, y, 0, x, y, Math.max(w, h) * 0.35);
          g.addColorStop(0, paleta[i][0]);
          g.addColorStop(1, 'transparent');
          ctx.fillStyle = g;
          ctx.fillRect(0, 0, w, h);
        }
        ctx.globalCompositeOperation = 'source-over';

        if (visivel) raf = requestAnimationFrame(desenhar);
      };

      // roda só enquanto a seção estiver na tela
      new IntersectionObserver((entries) => {
        visivel = entries[0].isIntersecting;
        cancelAnimationFrame(raf);
        if (visivel) raf = requestAnimationFrame(desenhar);
      }).observe(canvas);
    }
  }
</script>
